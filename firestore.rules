// Firestore Security Rules — ScamSentinel MY
// Reference: TECHSTACK_ScamSentinel_MY.md §6
//
// Deploy with:
//   firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Community KB — authenticated write, public read
    // Anyone can read the anonymised scam feed.
    // Only authenticated users (including anonymous auth) can submit reports.
    match /community_kb/{doc} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid != null;
    }

    // Scan logs — owner only
    // Each user can only read/write their own scan history.
    match /scans/{doc} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.user_id;
    }

    // Mule account index — service account write, public read
    // Citizens can check any account; only the backend service account can add entries.
    match /mule_accounts/{doc} {
      allow read: if true;
      allow write: if false; // service account only via Admin SDK (bypasses rules)
    }

    // Medium risk log — internal use only
    match /medium_risk_log/{doc} {
      allow read, write: if false; // service account only via Admin SDK
    }

    // Failed community pushes — internal retry queue
    match /failed_community_pushes/{doc} {
      allow read, write: if false; // service account only via Admin SDK
    }

    // Intercept logs — internal audit
    match /intercept_logs/{doc} {
      allow read, write: if false; // service account only via Admin SDK
    }

    // User profiles (FCM tokens, linked accounts)
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
