# ── ScamSentinel MY — Environment Variables ──────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to Git.

# Gemini Developer API key (from Secret Manager: gemini-api-key)
GEMINI_API_KEY=

# Path to Firebase Admin SDK service account JSON
# For local dev: point to your downloaded JSON file
# On Cloud Run: injected via --set-secrets
FIREBASE_SA_PATH=

# GCP project ID
GCP_PROJECT=scamsentinel-my

# GCP region
REGION=asia-southeast1

# Vertex AI Search data store ID (from Secret Manager: vertex-search-id)
VERTEX_SEARCH_DATASTORE_ID=

# ── Optional: Frontend URL for CORS (tighten in production) ─
FRONTEND_URL=http://localhost:5173
